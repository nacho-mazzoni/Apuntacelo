# ----------------------------------------------------------------------
# Dependencias generales
# ----------------------------------------------------------------------
node_modules/
.pnp/
.pnp.js

# ----------------------------------------------------------------------
# Salida de compilación de Next.js y otros artefactos
# ----------------------------------------------------------------------
.next/
dist/
out/
build/
.coverage/
.tmp/

# ----------------------------------------------------------------------
# Archivos de entorno y variables sensibles
# ----------------------------------------------------------------------
# Ignorar archivos .env con valores reales (incluye .env.local, .env.production, .env.test, etc.)
.env
.env.local
.env.production
.env.test
# Mantener los templates y ejemplos en el repositorio
!.env.example
!.env.template

# ----------------------------------------------------------------------
# Claves privadas, certificados y archivos secretos
# ----------------------------------------------------------------------
# Claves RSA/SSH y similares
*.key
*.pem
*.pk
*.crt
*.p12
*.secret
*.pub
# Directorio opcional para almacenar secretos manuales
secrets/
# Configuración de SSH local (no subir claves privadas)
.ssh/
# Configuración de IDE que puede contener credenciales
.vscode/
.idea/
# Otros archivos sensibles que puedan contener tokens o contraseñas
*.token
*.passwd
*.config

# ----------------------------------------------------------------------
# Archivos de logs y depuración
# ----------------------------------------------------------------------
logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.aider*
