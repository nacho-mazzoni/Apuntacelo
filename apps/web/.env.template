# WalletConnect Project ID (required for RainbowKit)
# Get yours at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=your_project_id_here

# Deployed contract address (after deploying to Celo)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# RPC URLs (optional, defaults provided in wallet-provider.tsx)
NEXT_PUBLIC_CELO_MAINNET_RPC=https://forno.celo.org
NEXT_PUBLIC_CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org/

# Pinata JWT (for IPFS uploads)
# Get yours at https://app.pinata.cloud/developers/api-keys
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_here
